<odoo>
    <record id="view_contact_form_form" model="ir.ui.view">
        <field name="name">contact.form.form</field>
        <field name="model">contact.form</field>
        <field name="arch" type="xml">
            <form string="Formulario de Contacto">
                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="correo_electronico"/>
                        <field name="telefono"/>
                        <field name="mensaje"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_contact_form" model="ir.actions.act_window">
        <field name="name">Contactos</field>
        <field name="res_model">contact.form</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_contact_form_root" name="Contactos"/>
    <menuitem id="menu_contact_form" name="Formulario de Contacto" parent="menu_contact_form_root" action="action_contact_form"/>
</odoo>