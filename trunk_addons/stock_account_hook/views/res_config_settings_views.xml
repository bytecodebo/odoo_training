<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="res_config_settings_view_form_inherit" model="ir.ui.view">
		<field name="name">res.config.settings.view.form.inherit.stock.account.sha</field>
		<field name="model">res.config.settings</field>
		<field name="inherit_id" ref="stock_account.res_config_settings_view_form" />
		<field name="arch" type="xml">
			<xpath expr="//div[@name='valuation_setting_container']" position="inside">
				<div class="col-12 col-lg-6 o_setting_box" id="group_journal_entries_grouped_po">
					<div class="o_setting_left_pane">
						<field name="svl_grouped_move_purchase" />
					</div>
					<div class="o_setting_right_pane">
						<label for="svl_grouped_move_purchase" />
						<div class="text-muted">
							Enable to create journal entry by picking for purchase.
						</div>
					</div>
				</div>

				<div class="col-12 col-lg-6 o_setting_box" id="group_journal_entries_grouped_so">
					<div class="o_setting_left_pane">
						<field name="svl_grouped_move_sale" />
					</div>
					<div class="o_setting_right_pane">
						<label for="svl_grouped_move_sale" />
						<div class="text-muted">
							Enable to create journal entry by picking for sale orders.
						</div>
					</div>
				</div>

			</xpath>
		</field>
	</record>

</odoo>