<?xml version="1.0" encoding="UTF-8"?>

<odoo>
	<data>
		<record model="ir.ui.view" id="wizard_get_report_form_view">
			<field name="name">wizard.get.report.form</field>
			<field name="model">wizard.get.report</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string="wizard get report">
					<sheet>
						<group>
							<field name="company_id" groups="base.group_multi_company"
							options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"/>
							<field name="partner_id" string="Company"
								   options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"/>
							<field name="start_date" required="1"/>
							<field name="end_date" required="1"/>
							<field name="name" required="1" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"
								   string="Report"/>
							<field name="ext" invisible="1"/>
							<field name="print_header" attrs="{'invisible': [('ext', 'in', ['pdf', 'xls', 'xlsx'])]}"/>
							<field name="separator" attrs="{'invisible': [('ext', 'in', ['pdf', 'xls', 'xlsx'])]}"/>
							<field name="paired_columns" attrs="{'invisible': [('ext', 'in', ['pdf', 'xls', 'xlsx'])]}"/>
						</group>
						<footer>
							<button name="get_report" string="Generate"
								type="object" invisible="1" />

							<button name="generate_report" string="Generate Report"
								type="object" class="btn-primary" /> or
							<button class="btn-secondary" special="cancel" string="Cancel" />
						</footer>
					</sheet>
				</form>
			</field>
		</record>

		<record model="ir.actions.act_window" id="act_wizard_get_report">
			<field name="name">Get Report</field>
            <field name="res_model">wizard.get.report</field>
			<field name="view_mode">form</field>
			<field name="target">new</field>
		</record>



	</data>
</odoo>
