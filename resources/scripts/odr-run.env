# Este archivo de variables debe ser copiado
# en el directorio raiz de los repositorios por cada proyecto
# Cambiar el nombre a .env

# Tag principal para manejar todos los proyectos
CONTEXT_PROJECT_TAG=Mya
# Tag principal de un proyecto especifico
CONTEXT_TAG=mya
# Direccion root del proyecto
CONTEXT_PATH=$(pwd)
# Tag para lectura de los modulos de un proyecto especifico
CONTEXT_FUNC_MODS=mya
# Nombre de instancia de un proyecto
# Parametro entrada: -i
CONTEXT_INSTANCE=trn
# Tipo de Ambiente de desarrollo o produccion
CONTEXT_ENV=tst
# Nombre especifico de base datos corto
# Parametro entrada: -d
CONTEXT_DB=training
# Tipo de accion a ejecutar por defecto update
# Parametro entrada: -o
CONTEXT_OPTION=u
# Modulos por defecto a ejecutar segun opcion False por defecto
# Parametro entrada: -m
CONTEXT_MODS=
# Sobreescribir traduccion False por defecto 1 yes
# Parametro entrada: -t
CONTEXT_TRANS=
# Accion opcional a realizar para recarga automatica del codigo
# Valores 1=reload   (python), 2=xml (vistas)  3=reload,xml  (archivos python y xml)
# Por defecto 3
# Parametro entrada: -x
CONTEXT_EXEC=3
# Version de odoo del proyecto
CONTEXT_ODOO_VERSION=16
# Direccion de repositorio de odoo
# e.g. ${CONTEXT_ODOO_SOURCE}/odoo-repo${CONTEXT_ODOO_VERSION}"
# ~/OdooRepo/odoo-repo16
CONTEXT_ODOO_SOURCE=$HOME/OdooRepo
# De esta manera se construye el path hacia el arhivo de configuracion de la instancia
# ${CONTEXT_SETTINGS}/${CONTEXT_PROJECT_TAG}/${CONTEXT_PROJECT_TAG}${CONTEXT_ODOO_VERSION}/conf
# e.g. ~/training-settings/Mya/Mya16/conf
CONTEXT_SETTINGS=$HOME/training-settings
# formato de archivo de configuracion odoo.conf
# e.g. od-${CONTEXT_INSTANCE}.conf
# e.g. ~/training-settings/Mya/Mya16/conf/od-trn.conf

# formato de nombre de base de datos
# ${CONTEXT_TAG}_${CONTEXT_ENV}_${CONTEXT_DB}
# e.g. trn_tst_training
# Version de python obtenida de pyenv
CONTEXT_PYTHON_ENV=$(pyenv local)