<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_config_settings_inherit_mst" model="ir.ui.view">
            <field name="name">view_config_settings_inherit_mst</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="General" string="Mya Settings"
                         data-key="trn_main_setting">
                        <h2>Company Settings</h2>
                        <div class="row mt16 o_settings_container" title="Company Settings" name="mya_company_settings">
                        </div>
                        <h2>Sales</h2>
                        <div class="row mt16 o_settings_container" title="Sale Settings" name="mya_div_sale">
                        </div>
                        <h2>General Settings</h2>
                        <div class="row mt16 o_settings_container" title="General Settings" name="mya_div_general">
                        </div>
                    </div>

                </xpath>
            </field>
        </record>


    </data>
</odoo>