<?xml version="1.0" encoding="utf-8"?>
  <odoo>

    <record id="pre_approve_form" model="ir.ui.view">
      <field name="name">pre.approve.wizard.form</field>
      <field name="model">pre.approve.wizard</field>
      <field name="mode">primary</field>
      <field name="inherit_id" ref="multi_step_wizard.multi_step_wizard_form"/>
      <field name="arch" type="xml">
        <xpath expr="//footer" position="before">
          <h1>
            <field name="partner_id" invisible="1"/>
            <field name="name" readonly="1"
                  class="oe_inline"
                  placeholder="Name"/>
          </h1>
          <group string="Documentation" name="doc" attrs="{'invisible': [('state', '!=', 'doc')]}">
            <group>
              <field name="document_id"/>
              <field name="photo"/>
            </group>
          </group>
          <group string="Evaluation" name="eva" attrs="{'invisible': [('state', '!=', 'eva')]}">
            <group>
              <field name="test_one" widget="boolean_toggle"/>
                <field name="test_two" string="Evaluation 2"/>
            </group>
          </group>
          <div name="final" attrs="{'invisible': [('state', '!=', 'final')]}">
            <p>Partner is now pre approved.</p>
          </div>
        </xpath>
      </field>
    </record>

    <record id="open_pre_approve" model="ir.actions.act_window">
        <field name="name">Pre Approval</field>
        <field name="res_model">pre.approve.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_partner" />
        <field name="binding_view_types">form</field>
    </record>

   <record id="action_open_pre_approve" model="ir.actions.act_window">
        <field name="name">Pre Approval</field>
       <field name="type">ir.actions.act_window</field>
        <field name="res_model">pre.approve.wizard</field>
       <field name="view_mode">form</field>
        <field name="view_id" ref="trn_partner_advance.pre_approve_form" />
        <field name="target">new</field>
    </record>
</odoo>