<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_config_settings_inherit_pad" model="ir.ui.view">
            <field name="name">view_config_settings_inherit_pad</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="trn_main_setting.view_config_settings_inherit_mst"/>
            <field name="arch" type="xml">
                 <xpath expr="//div[@name='mya_company_settings']" position="inside">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <button name="action_create_partner_demo"
                                            type="object"
                                            class="btn-primary"
                                            string="Create Partner Demos"/>
                                    <separator/>
                                </div>
                            </div>
                 </xpath>
            </field>
        </record>


    </data>
</odoo>