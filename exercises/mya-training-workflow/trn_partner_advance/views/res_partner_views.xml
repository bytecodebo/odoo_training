<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="view_inherit_res_partner_form_form" model="ir.ui.view">
            <field name="name">view.inherit.res.partner.form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <!-- position values: after|before|replace|attributes|inside -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_load_massive_customer"
                            class="oe_highlight"
                            type="object"
                            icon="fa-cogs"
                            string="Massive load"/>
                  <button name="action_pre_approval"
                          icon="fa-user"

                          class="oe_highlight" type="object" string="Pre Approval">
                     <div class="o_field_widget o_stat_info">
                                        <span class="o_stat_text">Pre</span>
                                        <span class="o_stat_text">Approval</span>
                                   </div>
                  </button>
                </xpath>
                <xpath expr="//field[@name='vat']" position="before">
                    <field name="siat_doc_type_id"
                           options="{'no_open': True, 'no_create_edit': True, 'no_create': True}"/>
                </xpath>
                  <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">NIT/CI/EXP</attribute>
                </xpath>
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="siat_extension_di"/>
                    <field name="full_vat"/>
                </xpath>
            </field>
        </record>

        <record id="view_res_partner_inherit_tree_inherit_tree" model="ir.ui.view">
            <field name="name">view.res.partner.inherit.tree</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vat']" position="after">
                      <field name="siat_extension_di" invisible="1"/>
                    <field name="siat_doc_type_id" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">NIT/CI/EXP</attribute>
                    <attribute name="invisible">1</attribute>
                </xpath>
                <!-- position values: after|before|replace|attributes|inside -->
                <xpath expr="//field[@name='phone']" position="before">
                    <field name="full_vat"/>
                </xpath>
            </field>
        </record>

        <record id="view_res_partner_inherit_search" model="ir.ui.view">
           <field name="name">view.res.partner.search</field>
           <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="filter_domain">['|', '|', '|', '|', '|', '|', ('display_name', 'ilike', self), ('ref', 'ilike', self),
                                                     ('email', 'ilike', self), ('vat', 'ilike', self), ('company_registry', 'ilike', self),
                                                     ('siat_extension_di', 'ilike', self), ('street', 'ilike', self)]
                    </attribute>
                </xpath>
                <xpath expr="//filter[@name='salesperson']" position="after">
                    <filter name="grp_doc_type" string="Document type" context="{'group_by': 'siat_doc_type_id'}"/>
                </xpath>
           </field>
        </record>
    </data>
</odoo>