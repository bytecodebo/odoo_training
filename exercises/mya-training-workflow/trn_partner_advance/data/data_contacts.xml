<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.sequence" id="seq_partner_advance_code">
            <field name="name">PartnerAdvanceSequence Code</field>
            <field name="padding">4</field>
            <field name="prefix">CLI-%(y)s-</field>
            <field name="implementation">standard</field>
            <field name="use_date_range" eval="1"/>
            <field name="range_reset">yearly</field>
            <field name="active">True</field>
        </record>

        <record model="res.partner.category" id="pad_category_user">
            <field name="name">User</field>
            <field name="active">True</field>
            <field name="color">2</field>
        </record>
        <record model="res.partner.category" id="pad_category_customer">
            <field name="name">Customer</field>
            <field name="active">True</field>
            <field name="color">3</field>
        </record>
    </data>
</odoo>