# repo of the url ssh o https eg github
# REPO_URL= git@github.com:bytecodebo
REPO_URL=git@github.com-rsv:robertsvx27
# Clone all repos required for project with this branch
BRANCH_NAME=16.0
# if depth = 0 ommit in clone, values >= 0
BRANCH_DEPTH=2
# if no  ommit in clone, values NO,no,N,n or YES,yes,Y,y
SINGLE_BRANCH=NO
# the main tag to filter projects
# if empty use base dir 
MAIN_TAG=mya16
#  the path where exists yaml files and scripts only for mani
# It is mandatory
MANI_SCRIPT=/home/rsaavedra/Developments/EntrenamientoOdoo16/repos-16/byc_tools/mani
#  the path where exists yaml files and scripts for sharing with others apps
#  by default is the same that MANI_SCRIPT
MANI_SCRIPT_SHARE=/home/rsaavedra/Developments/EntrenamientoOdoo16/repos-16/byc_tools/common_mani_sake
#  the path with the repos cloned or copied
# if empty or dot use current path
PROJECT_PATH=/home/rsaavedra/Developments/EntrenamientoOdoo16/repos-16
# the path where the file yaml projects will create 
# if empty use path from MANI_SCRIPT/MAIN_TAG/projects.yaml
# if dot is value projects will add in mani file
PROJECT_FILE_PATH=/home/rsaavedra/Developments/EntrenamientoOdoo16/repos-16
